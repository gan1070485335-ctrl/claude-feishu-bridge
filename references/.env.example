# Feishu app credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# Optional Feishu event security fields
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Allowlist: comma-separated sender open_id/user_id
FEISHU_ALLOW_FROM=

# AI provider in Anthropic Messages-compatible shape
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# Runtime
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
ENABLE_TEST_ENDPOINT=false

# Optional system prompt override
SYSTEM_PROMPT=你是一个中文技术助手，请简洁回答。
